{
  "name": "kubus",
  "version": "0.6.2",
  "private": true,
  "description": "Free, open-source Kubernetes GUI — multi-cluster browsing, logs, exec, port-forward, metrics, Helm",
  "license": "MIT",
  "engines": {
    "node": ">=24.17.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "build:helm-engine": "node helm-engine/build.mjs",
    "start": "node server/dist/index.js",
    "electron": "pnpm build && pnpm build:helm-engine && pnpm --filter @kubus/electron start",
    "dist": "pnpm build && pnpm build:helm-engine && pnpm --filter @kubus/electron dist",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @kubus/tests test",
    "test:watch": "pnpm --filter @kubus/tests test:watch",
    "test:coverage": "pnpm --filter @kubus/tests test:coverage",
    "test:e2e": "pnpm --filter @kubus/tests test:e2e",
    "test:electron": "pnpm --filter @kubus/tests test:electron",
    "smoke": "node hack/smoke-server.mjs",
    "lint": "oxlint . --deny-warnings",
    "lint:perf": "oxlint client/src -W perf",
    "serve-docs": "uvx --native-tls zensical serve --open",
    "build-docs": "uvx --native-tls zensical build --clean"
  },
  "devDependencies": {
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "playwright-core": "^1.61.1",
    "typescript": "^7.0.2"
  }
}
